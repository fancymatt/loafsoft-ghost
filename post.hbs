{{!< default}}

{{#post}}
    <main class="ls-main">
        <article class="ls-post">
            <header class="ls-post-hero"{{#if feature_image}} style="background-image: linear-gradient(180deg, rgba(45, 36, 36, 0.32) 0%, rgba(45, 36, 36, 0.82) 100%), url('{{img_url feature_image size="xxl"}}');"{{/if}}>
                <div class="ls-container ls-post-hero__inner">
                    <div class="ls-post-hero__content">
                        <h1>{{title}}</h1>
                        {{#if custom_excerpt}}
                            <p>{{custom_excerpt}}</p>
                        {{else}}
                            <p>{{excerpt words="22"}}</p>
                        {{/if}}
                        {{> "platform-badges"}}
                    </div>
                </div>
            </header>

            <section class="ls-post-body">
                <div class="ls-post-content">
                    {{content}}
                </div>
            </section>
        </article>
    </main>
{{/post}}
